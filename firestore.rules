rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Characters rules
    match /characters/{characterId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      function isValidCharacter(data) {
        return data.userId == request.auth.uid &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 64 &&
               data.level is number && data.level >= 1 && data.level <= 125 &&
               data.faction in ["Norrath's Keepers", "Dark Reign"] &&
               data.reputation is string &&
               data.reputationValue is number &&
               data.reputationValue >= -2000 && data.reputationValue <= 2000 &&
               data.completedTasks is list;
      }

      allow create: if isSignedIn() && 
                      isValidCharacter(request.resource.data) &&
                      request.resource.data.keys().hasAll(['userId', 'name', 'level', 'faction', 'reputation', 'reputationValue', 'completedTasks', 'createdAt', 'updatedAt']) &&
                      request.resource.data.keys().size() == 9 &&
                      request.resource.data.createdAt == request.time &&
                      request.resource.data.updatedAt == request.time;
      
      allow update: if isSignedIn() && isOwner(resource.data.userId) &&
                      isValidCharacter(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      request.resource.data.updatedAt == request.time &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'level', 'faction', 'reputation', 'reputationValue', 'completedTasks', 'updatedAt']);
      
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // User profile rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && request.resource.data.uid == userId;
    }
  }
}
