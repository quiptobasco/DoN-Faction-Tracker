rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function areFriends(uid1, uid2) {
      let id = uid1 < uid2 ? uid1 + "_" + uid2 : uid2 + "_" + uid1;
      return exists(/databases/$(database)/documents/friendships/$(id)) && 
             get(/databases/$(database)/documents/friendships/$(id)).data.status == 'accepted';
    }

    // Characters rules
    match /characters/{characterId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || areFriends(resource.data.userId, request.auth.uid));
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || areFriends(resource.data.userId, request.auth.uid));
      
      function isValidCharacter(data) {
        return data.userId == request.auth.uid &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 64 &&
               data.level is number && data.level >= 1 && data.level <= 125 &&
               data.faction in ["Norrath's Keepers", "Dark Reign"] &&
               data.reputation is string &&
               data.reputationValue is number &&
               data.reputationValue >= -2000 && data.reputationValue <= 2000 &&
               data.completedTasks is list;
      }

      allow create: if isSignedIn() && 
                      isValidCharacter(request.resource.data) &&
                      request.resource.data.keys().hasAll(['userId', 'name', 'level', 'faction', 'reputation', 'reputationValue', 'completedTasks', 'createdAt', 'updatedAt']) &&
                      request.resource.data.keys().size() == 9 &&
                      request.resource.data.createdAt == request.time &&
                      request.resource.data.updatedAt == request.time;
      
      allow update: if isSignedIn() && isOwner(resource.data.userId) &&
                      isValidCharacter(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      request.resource.data.updatedAt == request.time &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'level', 'faction', 'reputation', 'reputationValue', 'completedTasks', 'updatedAt']);
      
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // User profile rules
    match /users/{userId} {
      allow get: if isSignedIn(); 
      allow list: if isSignedIn(); // Simplified list for search queries
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && request.resource.data.uid == userId;
    }

    // Friendship rules
    match /friendships/{friendshipId} {
      allow get: if isSignedIn() && request.auth.uid in resource.data.uids;
      allow list: if isSignedIn() && resource.data.uids.hasAny([request.auth.uid]);
      allow create: if isSignedIn() && 
                      request.resource.data.requesterId == request.auth.uid &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.uids.size() == 2 &&
                      request.auth.uid in request.resource.data.uids &&
                      isValidId(request.resource.data.receiverId);
      allow update: if isSignedIn() && 
                      request.auth.uid in resource.data.uids &&
                      (
                        // Receiver accepts
                        (request.auth.uid == resource.data.receiverId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) && request.resource.data.status == 'accepted') ||
                        // Either party deletes/cancels (implemented via delete usually, but we can allow status update to 'rejected' if desired)
                        false
                      );
      allow delete: if isSignedIn() && request.auth.uid in resource.data.uids;
    }
  }
}
